{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "landingPage": "/",
  "preferredVersions": {
    "php": "8.2",
    "wp": "latest"
  },
  "phpExtensionBundles": ["kitchen-sink"],
  "features": {
    "networking": false
  },
  "steps": [
    {
      "step": "setSiteOptions",
      "options": {
        "blogname": "Demo Dispatch",
        "blogdescription": "A sample site for previewing WordPress themes."
      }
    },
    {
      "step": "importWxr",
      "file": {
        "resource": "url",
        "url": "https://raw.githubusercontent.com/WordPress/theme-test-data/main/v2/themeunittestdata-v2.xml"
      }
    },
    {
      "step": "writeFile",
      "path": "/wordpress/wp-content/uploads/demo-dispatch/README.txt",
      "data": "Demo Dispatch sample media. See the theme-test-data repo for the source illustrations and the full deliverable matrix (4 crops x 3 widths x 3 formats per subject).\n"
    },
    {
      "step": "runPHP",
      "code": "<?php require '/wordpress/wp-load.php'; update_option('show_on_front', 'posts');"
    }
  ]
}
